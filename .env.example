# Django settings
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Database (PostgreSQL) — omit to use SQLite locally
DATABASE_URL=postgresql://yeolab:password@localhost:5432/yeolab_publications

# Globus OAuth2 (register at https://app.globus.org/settings/developers)
GLOBUS_CLIENT_ID=
GLOBUS_CLIENT_SECRET=
GLOBUS_ADMIN_GROUP=f0c3d900-18af-11f1-8e43-0affecd7d007
SOCIAL_AUTH_GLOBUS_REDIRECT_URI=https://yourdomain.com/complete/globus/

# Optional: Code Examples Editor GitHub sync
GITHUB_PAT=
GITHUB_REPO=byee4/yeolab-publications-db
GITHUB_BRANCH=main
CODE_EXAMPLES_REPO_DIR=/app/yeolab-publications-db
GUNICORN_TIMEOUT=600

# Optional: NCBI API key for faster PubMed/GEO fetching
NCBI_API_KEY=
ENTREZ_EMAIL=your-email@example.com

# Optional: disable SSL redirect behind a load balancer that handles SSL
SECURE_SSL_REDIRECT=True
